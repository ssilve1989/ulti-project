{
  "name": "ulti-project",
  "version": "2.0.0",
  "description": "Ulti-Project Discord Bot",
  "author": "Aeo <aeo.games14@gmail.com>",
  "type": "module",
  "private": true,
  "license": "UNLICENSED",
  "main": "dist/main.js",
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=22.22.3"
  },
  "scripts": {
    "build": "rimraf dist && tsgo -p tsconfig.build.json",
    "build:cli": "rimraf dist/cli && tsgo -p tsconfig.cli.json",
    "build:all": "rimraf dist && tsgo -p tsconfig.build.json && tsgo -p tsconfig.cli.json",
    "check": "biome check",
    "commit": "git-cz",
    "commitlint": "commitlint --edit",
    "docker:build": "docker build . -t ulti-project-bot:latest",
    "format": "biome format --write",
    "g:slash-command": "hygen slash-command new",
    "graphql:codegen": "graphql-codegen --config codegen.ts",
    "lint": "biome lint --diagnostic-level=error",
    "lint:ci": "biome ci --diagnostic-level=error",
    "prepare": "node scripts/install-hooks.js",
    "start:dev:sentry": "NODE_OPTIONS=\"--import=./instrumentation.ts\" pnpm start:dev",
    "cli": "dotenvx run -f .env -f .env.development -- node dist/cli/main.js",
    "cli:prod": "dotenvx run -f .env -f .env.production -- node dist/cli/main.js",
    "start": "dotenvx run -f .env -f .env.production -- node dist/main",
    "start:dev": "dotenvx run -f .env -f .env.development -- node dist/main.js",
    "test": "vitest",
    "test:ci": "CI=true vitest run --coverage",
    "test:cov": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "typecheck": "tsgo -p tsconfig.app.json --noEmit && tsgo -p src/cli/tsconfig.json --noEmit",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org ulti-project --project ulti-project-bot ./dist && sentry-cli sourcemaps upload --org ulti-project --project ulti-project-bot ./dist"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.71.0",
    "@googleapis/sheets": "^13.0.2",
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.24",
    "@nestjs/cqrs": "^11.0.3",
    "@sentry/cli": "^3.4.3",
    "@sentry/nestjs": "^10.54.0",
    "@sentry/profiling-node": "^10.54.0",
    "cron": "^4.4.0",
    "discord.js": "^14.26.4",
    "firebase-admin": "^13.10.0",
    "google-auth-library": "^10.6.2",
    "graphql": "^16.14.1",
    "graphql-request": "^7.4.0",
    "nestjs-pino": "^4.6.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "title-case": "^4.3.2",
    "ts-pattern": "^5.9.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@clack/prompts": "^1.5.1",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@commitlint/cz-commitlint": "^21.0.2",
    "@commitlint/prompt-cli": "^21.0.2",
    "@flydotio/dockerfile": "^0.7.10",
    "@graphql-codegen/cli": "7.1.2",
    "@graphql-codegen/schema-ast": "^6.0.1",
    "@graphql-codegen/typescript": "6.0.2",
    "@graphql-codegen/typescript-graphql-request": "^7.1.0",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.24",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "7.0.0-dev.20260608.1",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "commander": "^14.0.3",
    "commitizen": "^4.3.1",
    "hygen": "^6.2.11",
    "lefthook": "^2.1.9",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.8"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  }
}
