{
  "name": "ulti-project",
  "version": "1.40.3",
  "description": "Ulti-Project Discord Bot",
  "author": "Aeo <aeo.games14@gmail.com>",
  "type": "module",
  "private": true,
  "license": "UNLICENSED",
  "main": "dist/main.js",
  "engines": {
    "node": ">=22.22.2"
  },
  "scripts": {
    "build": "rimraf dist && tsgo -p tsconfig.build.json",
    "check": "biome check",
    "commit": "git-cz",
    "commitlint": "commitlint --edit",
    "docker:build": "docker build . -t ulti-project-bot:latest",
    "format": "biome format --write",
    "g:slash-command": "hygen slash-command new",
    "graphql:codegen": "graphql-codegen --config codegen.ts",
    "lint": "biome lint --diagnostic-level=error",
    "lint:ci": "biome ci --diagnostic-level=error",
    "prepare": "node scripts/install-hooks.js",
    "start:sentry": "NODE_OPTIONS=\"--import=./instrumentation.mjs\" pnpm start",
    "cli": "dotenvx run -f .env -f .env.development -- bun src/cli/main.ts",
    "cli:prod": "dotenvx run -f .env -f .env.development -- bun src/cli/main.ts",
    "start": "dotenvx run -f .env -f .env.development -- node dist/main",
    "test": "vitest",
    "test:ci": "CI=true vitest run --coverage",
    "test:cov": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "typecheck": "tsgo -p tsconfig.app.json --noEmit && tsgo -p src/cli/tsconfig.json --noEmit",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org ulti-project --project ulti-project-bot ./dist && sentry-cli sourcemaps upload --org ulti-project --project ulti-project-bot ./dist"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.61.4",
    "@googleapis/sheets": "^13.0.1",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/cqrs": "^11.0.3",
    "@sentry/cli": "^3.4.0",
    "@sentry/nestjs": "^10.49.0",
    "@sentry/profiling-node": "^10.49.0",
    "cron": "^4.4.0",
    "dayjs": "^1.11.20",
    "discord.js": "^14.26.3",
    "firebase-admin": "^13.8.0",
    "google-auth-library": "^10.6.2",
    "graphql": "^16.13.2",
    "graphql-request": "^7.4.0",
    "nestjs-pino": "^4.6.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "title-case": "^4.3.2",
    "ts-pattern": "^5.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/cz-commitlint": "^20.5.1",
    "@commitlint/prompt-cli": "^20.5.0",
    "@clack/prompts": "^1.2.0",
    "@flydotio/dockerfile": "^0.7.10",
    "@graphql-codegen/cli": "6.3.1",
    "@graphql-codegen/schema-ast": "^5.0.2",
    "@graphql-codegen/typescript": "5.0.10",
    "@graphql-codegen/typescript-graphql-request": "^7.0.1",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260427.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "commander": "^14.0.3",
    "commitizen": "^4.3.1",
    "hygen": "^6.2.11",
    "lefthook": "^2.1.6",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.4"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "lefthook",
      "@firebase/util",
      "@nestjs/core",
      "@sentry-internal/node-cpu-profiler",
      "@sentry/cli",
      "@swc/core",
      "esbuild",
      "nestjs-pino"
    ],
    "ignoredBuiltDependencies": [
      "protobufjs"
    ]
  }
}
