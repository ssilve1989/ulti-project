{
  "$schema": "https://json.schemastore.org/tsconfig",
  // Solution-style root config. It owns no files of its own; it just wires the
  // project graph together so `tsc -b` type-checks every file exactly once, in
  // dependency order. The `cli` project references `src` and consumes its
  // declarations instead of re-compiling the shared firebase/encounters/config
  // modules. Tests live alongside the source they exercise (inside `src`) so
  // specs that reach private members keep full type information. Shared compiler
  // options live in `tsconfig.base.json`; the production build is driven by
  // `tsconfig.build.json` and `tsconfig.cli.json`.
  "files": [],
  "references": [
    { "path": "./tsconfig.src.json" },
    { "path": "./src/cli/tsconfig.json" }
  ]
}
