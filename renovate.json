{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices", ":preserveSemverRanges"],
  "schedule": ["before 9am on monday"],
  "minimumReleaseAge": "5 days",
  "prConcurrentLimit": 10,
  "ignorePaths": ["Dockerfile"],
  "packageRules": [
    {
      "description": "Automerge minor/patch/digest updates",
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "NestJS packages",
      "matchPackageNames": [
        "@nestjs/common",
        "@nestjs/core",
        "@nestjs/cqrs",
        "@nestjs/schematics",
        "@nestjs/testing",
        "@nestjs/cli"
      ],
      "groupName": "nest"
    },
    {
      "description": "Pino packages",
      "matchPackageNames": ["pino-http", "pino-pretty"],
      "groupName": "pino"
    },
    {
      "description": "Commitlint packages",
      "groupName": "commitlint",
      "matchPackageNames": ["/^@commitlint/"]
    },
    {
      "description": "Sentry packages",
      "groupName": "sentry",
      "matchPackageNames": ["/^@sentry/"]
    },
    {
      "description": "Vite and Vitest packages",
      "matchPackageNames": [
        "@vitest/ui",
        "@vitest/coverage-v8",
        "vitest",
        "vite"
      ],
      "groupName": "vite"
    },
    {
      "description": "GraphQL Codegen packages",
      "groupName": "graphql",
      "matchPackageNames": ["/^@graphql-codegen/"]
    },
    {
      "description": "GitHub Actions",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    }
  ]
}
